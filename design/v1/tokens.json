{
  "meta": {
    "name": "MyUI",
    "version": "1.1.0",
    "description": "Minecraft Fabric UI Mod + Electron Launcher design tokens"
  },
  "color": {
    "accent": "#5AC8FA",
    "accent72": "rgba(90, 200, 250, 0.72)",
    "accent24": "rgba(90, 200, 250, 0.24)",
    "accent12": "rgba(90, 200, 250, 0.12)",
    "bgDeep": "oklch(12% 0.02 250)",
    "bgOverlay": "rgba(8, 12, 20, 0.55)",
    "glassBg": "rgba(255, 255, 255, 0.08)",
    "glassBgStrong": "rgba(255, 255, 255, 0.14)",
    "glassBorder": "rgba(255, 255, 255, 0.22)",
    "glassBorderAccent": "rgba(90, 200, 250, 0.45)",
    "fg": "oklch(96% 0.005 250)",
    "fgMuted": "oklch(72% 0.01 250)",
    "fgDim": "oklch(52% 0.012 250)",
    "danger": "oklch(62% 0.18 25)",
    "success": "oklch(68% 0.14 155)"
  },
  "typography": {
    "fontDisplay": "'Alibaba PuHuiTi', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', system-ui, sans-serif",
    "fontBody": "'Alibaba PuHuiTi', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', system-ui, sans-serif",
    "fontMono": "'SF Mono', 'JetBrains Mono', ui-monospace, monospace",
    "scale": {
      "titleXl": { "size": "28px", "weight": 600, "tracking": "-0.02em" },
      "titleLg": { "size": "22px", "weight": 600, "tracking": "-0.01em" },
      "menuItem": { "size": "18px", "weight": 500, "tracking": "0" },
      "body": { "size": "15px", "weight": 400, "tracking": "0" },
      "caption": { "size": "12px", "weight": 400, "tracking": "0.02em" },
      "label": { "size": "11px", "weight": 600, "tracking": "0.06em" }
    }
  },
  "spacing": {
    "xs": "4px",
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px"
  },
  "radius": {
    "sm": "8px",
    "md": "14px",
    "lg": "20px",
    "pill": "999px"
  },
  "glass": {
    "blurMin": "18px",
    "blurDefault": "20px",
    "blurMax": "24px",
    "saturation": "160%",
    "borderWidth": "2px"
  },
  "motion": {
    "pageTransition": { "type": "crossfade", "durationMs": 180, "slidePx": 0 },
    "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)",
    "springGentle": "cubic-bezier(0.22, 1.2, 0.36, 1)",
    "durationFast": "180ms",
    "durationNormal": "320ms",
    "hoverScale": 1.05,
    "activeScale": 0.97
  },
  "component": {
    "profileCard": { "width": "280px", "padding": "20px", "avatarSize": "48px", "blur": "22px" },
    "menuButton": { "height": "44px", "iconSize": "24px" },
    "contentPanel": { "width": "720px", "minHeight": "640px" },
    "tabBar": { "tabs": ["general", "background", "theme", "animation", "reload"], "indicatorHeight": "2px" }
  },
  "icon": {
    "viewBox": "64 64",
    "strokeWidth": 2,
    "strokeLinecap": "round",
    "strokeLinejoin": "round",
    "fill": "none"
  }
}
